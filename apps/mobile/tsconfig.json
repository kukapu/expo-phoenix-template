{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "vitest/globals",
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@snack/contracts": [
        "../../packages/contracts/src/index.ts"
      ],
      "@snack/mobile-shared": [
        "../../packages/mobile-shared/src/index.ts"
      ]
    }
  },
  "include": [
    "app",
    "src",
    "test",
    "vitest.config.ts"
  ],
  "extends": "expo/tsconfig.base"
}
