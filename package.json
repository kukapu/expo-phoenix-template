{
  "name": "snack",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "bash ./scripts/test-mobile.sh && bash ./scripts/test-backend.sh",
    "test:mobile": "bash ./scripts/test-mobile.sh",
    "test:backend": "bash ./scripts/test-backend.sh",
    "test:contracts": "pnpm --filter @snack/contracts test",
    "bootstrap:mobile": "pnpm install"
  },
  "devDependencies": {
    "turbo": "2.5.8"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.27.0",
      "lightningcss-linux-x64-gnu": "1.27.0"
    }
  }
}
